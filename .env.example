DATABASE_URL="file:./dev.db"
# Produksi (PostgreSQL/Supabase): DATABASE_URL = pooled connection (port 6543,
# pgbouncer=true), DIRECT_URL = direct connection (port 5432, dipakai `prisma db push`).
DIRECT_URL=""
MOCK_CONNECTORS="true"
AI_PROVIDER="mock"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-v4-flash"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
X_BEARER_TOKEN=""
FB_PAGE_ID=""
FB_ACCESS_TOKEN=""
IG_USER_ID=""
IG_ACCESS_TOKEN=""
THREADS_USER_ID=""
THREADS_ACCESS_TOKEN=""
TIKTOK_ACCESS_TOKEN=""
YOUTUBE_API_KEY=""
BLOG_RSS_FEEDS=""
ENSEMBLEDATA_TOKEN=""
APIFY_TOKEN=""
# Optional override for the Instagram Actor slug/ID, e.g. username~actor-name
APIFY_INSTAGRAM_ACTOR_ID=""
# Komentar per post yang diambil di tahap ke-2 fetch (default 10 jika kosong)
APIFY_INSTAGRAM_COMMENTS_LIMIT=""
# Facebook (Apify) — owned account: post + TEKS LENGKAP komentar. Verifikasi
# aktor pilihan Anda di Apify Store sebelum produksi (lihat catatan di
# src/lib/connectors/apify-connector.ts).
APIFY_FACEBOOK_ACTOR_ID=""
APIFY_FACEBOOK_COMMENTS_ACTOR_ID=""
APIFY_FACEBOOK_COMMENTS_LIMIT=""
# X/Twitter (Apify) — pencarian publik keyword/frasa, tanpa reply/komentar.
APIFY_X_ACTOR_ID=""
# Threads (Apify) — pencarian publik keyword/frasa, tanpa reply/komentar.
APIFY_THREADS_ACTOR_ID=""
# TikTok (Apify) — pencarian publik keyword/frasa video. Komentar direncanakan
# fase berikutnya.
APIFY_TIKTOK_ACTOR_ID=""
NEWSDATA_API_KEY=""
BASIC_AUTH_ENABLED="false"
BASIC_AUTH_USER="admin"
BASIC_AUTH_PASSWORD="brandpulse"
