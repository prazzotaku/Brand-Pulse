DATABASE_URL="file:./dev.db"
# Produksi (PostgreSQL/Supabase): DATABASE_URL = pooled connection (port 6543,
# pgbouncer=true), DIRECT_URL = direct connection (port 5432, dipakai `prisma db push`).
DIRECT_URL=""
MOCK_CONNECTORS="true"
AI_PROVIDER="mock"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-v4-flash"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
X_BEARER_TOKEN=""
FB_PAGE_ID=""
FB_ACCESS_TOKEN=""
IG_USER_ID=""
IG_ACCESS_TOKEN=""
THREADS_USER_ID=""
THREADS_ACCESS_TOKEN=""
TIKTOK_ACCESS_TOKEN=""
YOUTUBE_API_KEY=""
BLOG_RSS_FEEDS=""
ENSEMBLEDATA_TOKEN=""

# Cron secret untuk mengamankan endpoint cron job dari pemanggilan publik.
# Harus sama dengan yang di-set di Vercel env.
CRON_SECRET=""

NEWSDATA_API_KEY=""
BASIC_AUTH_ENABLED="false"
BASIC_AUTH_USER="admin"
BASIC_AUTH_PASSWORD="brandpulse"
